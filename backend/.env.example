# Database
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/solidy_contracts"

# Authentication
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

# Server
PORT=3333
NODE_ENV="development"

# SMTP (e-mail para assinatura eletrônica)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM="Solidy Contracts <your-email@gmail.com>"

# WhatsApp (Evolution API ou Twilio)
WHATSAPP_API_URL="https://your-whatsapp-api.com"
WHATSAPP_API_KEY="your-whatsapp-api-key"
WHATSAPP_INSTANCE="default"

# App URL (usado nos links dos e-mails de assinatura)
APP_URL="http://localhost:5173"
API_URL="http://localhost:3333"
